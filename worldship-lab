<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Visual Shipper - UPS</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
:root {
  --accent: #FFB500;
  --accent-hover: #351C15;
  --vs2006-blue: #351C15;
  --ups-brown: #351C15;
  --ups-gold: #FFB500;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: #f3f4f6;
}

.login-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #351C15 0%, #4A2A1F 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  transition: opacity 0.4s ease, visibility 0.4s ease;
}

.login-overlay.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.login-card {
  background: white;
  padding: 2.5rem;
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  width: 90%;
  max-width: 420px;
  animation: slideIn 0.5s ease;
}

@keyframes slideIn {
  from {
    transform: translateY(-30px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.login-logo {
  text-align: center;
  margin-bottom: 2rem;
}

.login-logo h1 {
  font-size: 2rem;
  font-weight: 800;
  color: #351C15;
  margin-bottom: 0.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}

.login-logo p {
  color: #666;
  font-size: 0.95rem;
  letter-spacing: 0.5px;
}

.login-input {
  width: 100%;
  padding: 0.875rem 1rem;
  border: 2px solid #e5e7eb;
  border-radius: 8px;
  font-size: 1rem;
  transition: all 0.2s;
  margin-bottom: 1rem;
}

.login-input:focus {
  outline: none;
  border-color: #FFB500;
  box-shadow: 0 0 0 3px rgba(255, 181, 0, 0.15);
}

.login-btn {
  width: 100%;
  padding: 0.875rem;
  background: #351C15;
  color: #FFB500;
  border: none;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}

.login-btn:hover {
  background: #FFB500;
  color: #351C15;
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(255, 181, 0, 0.4);
}

.login-btn:active {
  transform: translateY(0);
}

.login-footer {
  text-align: center;
  margin-top: 1.5rem;
  font-size: 0.85rem;
  color: #999;
}

.app-container {
  display: none;
  width: 100%;
  min-height: 100vh;
}

.app-container.active {
  display: block;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f9fafb;
  flex-direction: column;
  gap: 1rem;
}

.spinner {
  width: 48px;
  height: 48px;
  border: 4px solid #e5e7eb;
  border-top-color: #351C15;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Tab System Fix Styles */
.vs-tab-content {
  display: none;
  animation: fadeIn 0.3s ease;
}

.vs-tab-content.active {
  display: block;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.vs-tab-btn.active {
  background: #351C15 !important;
  color: #FFB500 !important;
  border-bottom: 3px solid #FFB500;
}

.vs-tab-btn {
  transition: all 0.2s ease;
}

.vs-tab-btn:hover:not(.active) {
  background: rgba(53, 28, 21, 0.1);
}

@media (max-width: 768px) {
  .vs-tab-nav {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .vs-tab-nav::-webkit-scrollbar {
    display: none;
  }
  .vs-tab-btn {
    white-space: nowrap;
    min-width: max-content;
  }
}

@media (max-width: 390px) {
  .login-card {
    padding: 1.75rem;
  }
  .login-logo h1 {
    font-size: 1.75rem;
  }
}
</style>
</head>
<body>
<div id="loginOverlay" class="login-overlay">
  <div class="login-card">
    <div class="login-logo">
      <h1><i class="fa-solid fa-box"></i> Visual Shipper</h1>
      <p>UPS Enterprise Shipping Platform</p>
    </div>
    <form id="loginForm">
      <input type="text" id="username" class="login-input" placeholder="Username" value="admin" required>
      <input type="password" id="password" class="login-input" placeholder="Password" value="ups2024" required>
      <button type="submit" class="login-btn" id="loginBtn">
        <i class="fa-solid fa-right-to-bracket"></i> Login
      </button>
    </form>
    <div class="login-footer">
      © 2024 United Parcel Service
    </div>
  </div>
</div>

<div id="appContainer" class="app-container">
  <div class="loading-state" id="loadingState">
    <div class="spinner"></div>
    <p style="color: #666; font-weight: 500;">Loading Visual Shipper...</p>
  </div>
</div>

<img id="vsOriginalContent" src="data:text/html;base64," hidden>

<script>
(function() {
  const loginForm = document.getElementById('loginForm');
  const loginOverlay = document.getElementById('loginOverlay');
  const appContainer = document.getElementById('appContainer');
  const loadingState = document.getElementById('loadingState');
  let contentLoaded = false;

  loginForm.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const username = document.getElementById('username').value.trim();
    const password = document.getElementById('password').value.trim();
    
    if (!username || !password) return;
    
    const loginBtn = document.getElementById('loginBtn');
    loginBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Signing in...';
    loginBtn.disabled = true;
    
    setTimeout(() => {
      loginOverlay.classList.add('hidden');
      appContainer.classList.add('active');
      loadOriginalContent();
    }, 400);
  });

  async function loadOriginalContent() {
    if (contentLoaded) return;
    contentLoaded = true;
    
    try {
      const contentImg = document.getElementById('vsOriginalContent');
      const response = await fetch(contentImg.src);
      
      if (!response.ok) {
        throw new Error('Failed to load content');
      }
      
      const html = await response.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      
      // Extract and inject head styles/scripts with UPS color overrides
      doc.head.querySelectorAll('style').forEach(style => {
        const newStyle = document.createElement('style');
        let cssText = style.textContent;
        cssText = cssText.replace(/--accent:\s*[^;]+;/gi, '--accent: #FFB500;');
        cssText = cssText.replace(/--accent-hover:\s*[^;]+;/gi, '--accent-hover: #351C15;');
        cssText = cssText.replace(/--vs2006-blue:\s*[^;]+;/gi, '--vs2006-blue: #351C15;');
        cssText = cssText.replace(/#FFB500/gi, '#FFB500');
        cssText = cssText.replace(/#351C15/gi, '#351C15');
        cssText = cssText.replace(/rgb\(255,\s*181,\s*0\)/gi, '#FFB500');
        cssText = cssText.replace(/rgb\(53,\s*28,\s*21\)/gi, '#351C15');
        newStyle.textContent = cssText;
        document.head.appendChild(newStyle);
      });
      
      doc.head.querySelectorAll('link[rel="stylesheet"]').forEach(link => {
        if (!link.href.includes('font-awesome')) {
          const newLink = document.createElement('link');
          newLink.rel = 'stylesheet';
          newLink.href = link.href;
          document.head.appendChild(newLink);
        }
      });
      
      loadingState.style.display = 'none';
      appContainer.innerHTML = doc.body.innerHTML;
      
      // Apply UPS color overrides to inline styles
      appContainer.querySelectorAll('*').forEach(el => {
        if (el.style.backgroundColor === 'rgb(255, 181, 0)' || el.style.background === '#FFB500') {
          el.style.backgroundColor = '#FFB500';
        }
        if (el.style.color === 'rgb(53, 28, 21)' || el.style.color === '#351C15') {
          el.style.color = '#351C15';
        }
      });
      
      // Execute scripts from original file
      const scriptPromises = [];
      doc.head.querySelectorAll('script').forEach(oldScript => {
        if (!oldScript.src.includes('tailwindcss')) {
          scriptPromises.push(injectScript(oldScript));
        }
      });
      
      await Promise.all(scriptPromises);
      
      const bodyScriptPromises = [];
      doc.body.querySelectorAll('script').forEach(oldScript => {
        bodyScriptPromises.push(injectScript(oldScript));
      });
      
      await Promise.all(bodyScriptPromises);
      
      // Initialize tab switching after content loads
      setTimeout(() => {
        initializeTabSystem();
      }, 100);
      
    } catch (err) {
      console.error('Error loading Visual Shipper content:', err);
      loadingState.innerHTML = `
        <div style="text-align: center; padding: 2rem;">
          <i class="fa-solid fa-triangle-exclamation" style="font-size: 3rem; color: #EF4444; margin-bottom: 1rem;"></i>
          <p style="color: #374151; font-weight: 600; margin-bottom: 0.5rem;">Failed to load Visual Shipper</p>
          <p style="color: #6B7280; font-size: 0.9rem;">Please check that Visual-Shipper-2_1.html is available.</p>
          <p style="color: #9CA3AF; font-size: 0.8rem; margin-top: 0.5rem;">Error: ${err.message}</p>
        </div>
      `;
    }
  }

  function injectScript(oldScript) {
    return new Promise((resolve) => {
      const newScript = document.createElement('script');
      if (oldScript.src) {
        newScript.src = oldScript.src;
        newScript.onload = () => resolve();
        newScript.onerror = () => resolve();
      } else {
        newScript.textContent = oldScript.textContent;
        resolve();
      }
      if (oldScript.type) newScript.type = oldScript.type;
      document.body.appendChild(newScript);
      if (!oldScript.src) resolve();
    });
  }

  function initializeTabSystem() {
    // Find all tab buttons and content panels
    const tabButtons = document.querySelectorAll('[data-tab], .tab-btn, .vs-tab-btn, button[onclick*="showTab"], button[onclick*="switchTab"]');
    const tabContents = document.querySelectorAll('[data-tab-content], .tab-content, .vs-tab-content');
    
    // Tab mapping for Visual Shipper
    const tabMap = {
      'shipper-options': 'shipper-options',
      'configuration': 'configuration', 
      'shipper-swap': 'shipper-swap',
      'lan-settings': 'lan-settings',
      'sql-server': 'sql-server-database',
      'sql-server-database': 'sql-server-database',
      'ms-access': 'ms-access-database',
      'ms-access-database': 'ms-access-database',
      'nrf-xml': 'nrf-xml',
      'xml': 'nrf-xml',
      'about': 'about',
      'help': 'help'
    };

    function showTab(tabId) {
      // Normalize tab ID
      const normalizedId = tabMap[tabId] || tabId;
      
      // Hide all tab contents
      tabContents.forEach(content => {
        content.classList.remove('active');
        content.style.display = 'none';
      });
      
      // Remove active state from all buttons
      tabButtons.forEach(btn => {
        btn.classList.remove('active');
        btn.setAttribute('aria-selected', 'false');
      });
      
      // Show selected tab content
      const targetContent = 
        document.querySelector(`[data-tab-content="${normalizedId}"]`) ||
        document.querySelector(`#${normalizedId}`) ||
        document.querySelector(`.tab-content[data-id="${normalizedId}"]`) ||
        document.getElementById(normalizedId);
        
      if (targetContent) {
        targetContent.classList.add('active');
        targetContent.style.display = 'block';
      }
      
      // Activate corresponding button
      const targetButton = 
        document.querySelector(`[data-tab="${tabId}"]`) ||
        document.querySelector(`[data-tab="${normalizedId}"]`) ||
        document.querySelector(`button[onclick*="${tabId}"]`);
        
      if (targetButton) {
        targetButton.classList.add('active');
        targetButton.setAttribute('aria-selected', 'true');
      }
    }

    // Attach click handlers to all tab buttons
    tabButtons.forEach(btn => {
      const tabId = btn.getAttribute('data-tab') || 
                   btn.getAttribute('data-id') ||
                   btn.id ||
                   extractTabIdFromOnclick(btn.getAttribute('onclick'));
      
      if (tabId) {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          showTab(tabId);
        });
        
        // Add UPS styling
        btn.classList.add('vs-tab-btn');
      }
    });

    // Initialize with first tab or Shipper Options
    const firstTab = document.querySelector('[data-tab="shipper-options"], [data-tab="configuration"]');
    if (firstTab) {
      const tabId = firstTab.getAttribute('data-tab');
      showTab(tabId);
    } else if (tabButtons.length > 0) {
      tabButtons[0].click();
    }

    // Ensure all tab content divs have proper class
    document.querySelectorAll('#shipper-options, #configuration, #shipper-swap, #lan-settings, #sql-server-database, #ms-access-database, #nrf-xml, #about, #help').forEach(div => {
      div.classList.add('vs-tab-content');
      if (!div.classList.contains('active')) {
        div.style.display = 'none';
      }
    });

    // Override any existing showTab/switchTab functions
    window.showTab = showTab;
    window.switchTab = showTab;
  }

  function extractTabIdFromOnclick(onclickStr) {
    if (!onclickStr) return null;
    const match = onclickStr.match(/['"]([\w-]+)['"]/);
    return match ? match[1] : null;
  }
})();
</script>
