    <script>
        // Server data
        const servers = [
            { name: 'PL-DB-01', status: 'critical', cpu: 94, memory: 87, diskio: 127, bottleneck: 'Disk I/O' },
            { name: 'PL-APP-03', status: 'warning', cpu: 76, memory: 94, diskio: 45, bottleneck: 'Memory' },
            { name: 'PL-WEB-05', status: 'healthy', cpu: 42, memory: 56, diskio: 23, bottleneck: 'None' },
            { name: 'PL-FILE-07', status: 'healthy', cpu: 38, memory: 62, diskio: 18, bottleneck: 'None' },
            { name: 'PL-MAIL-02', status: 'warning', cpu: 81, memory: 71, diskio: 67, bottleneck: 'CPU' },
            { name: 'PL-TEST-09', status: 'healthy', cpu: 28, memory: 45, diskio: 12, bottleneck: 'None' },
            { name: 'PL-BACKUP-11', status: 'healthy', cpu: 15, memory: 34, diskio: 89, bottleneck: 'None' },
            { name: 'PL-DEV-04', status: 'healthy', cpu: 51, memory: 58, diskio: 34, bottleneck: 'None' },
            { name: 'PL-PROXY-06', status: 'critical', cpu: 91, memory: 88, diskio: 54, bottleneck: 'CPU/Memory' },
            { name: 'PL-DNS-08', status: 'healthy', cpu: 22, memory: 31, diskio: 8, bottleneck: 'None' },
            { name: 'PL-STORAGE-10', status: 'warning', cpu: 67, memory: 79, diskio: 102, bottleneck: 'Disk I/O' },
            { name: 'PL-VPN-12', status: 'healthy', cpu: 44, memory: 52, diskio: 19, bottleneck: 'None' }
        ];

        // Populate server table for desktop
        function renderServerTable() {
            const tbody = document.getElementById('serverTableBody');
            tbody.innerHTML = servers.map(server => `
                <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium">${server.name}</td>
                    <td class="px-4 py-3">
                        <span class="flex items-center gap-2">
                            <span class="status-dot status-${server.status}"></span>
                            <span class="capitalize text-xs">${server.status}</span>
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                            <div class="metric-bar flex-1 max-w-[80px]">
                                <div class="metric-fill" style="width: ${server.cpu}%; background: ${server.cpu > 85 ? '#D32F2F' : server.cpu > 70 ? '#F57C00' : '#388E3C'}"></div>
                            </div>
                            <span class="text-xs w-8">${server.cpu}%</span>
                        </div>
                    </td>
                    <td class="px-4 py-3 hide-mobile">
                        <div class="flex items-center gap-2">
                            <div class="metric-bar flex-1 max-w-[80px]">
                                <div class="metric-fill" style="width: ${server.memory}%; background: ${server.memory > 90 ? '#D32F2F' : server.memory > 75 ? '#F57C00' : '#388E3C'}"></div>
                            </div>
                            <span class="text-xs w-8">${server.memory}%</span>
                        </div>
                    </td>
                    <td class="px-4 py-3 hide-mobile text-xs">${server.diskio}ms</td>
                    <td class="px-4 py-3">
                        <span class="text-xs px-2 py-1 rounded ${server.bottleneck === 'None' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">${server.bottleneck}</span>
                    </td>
                </tr>
            `).join('');
        }

        // Populate server cards for mobile
        function renderServerCards() {
            const container = document.getElementById('serverCardContainer');
            container.innerHTML = servers.map(server => `
                <div class="p-4">
                    <div class="flex items-start justify-between mb-3">
                        <div class="flex-1">
                            <h4 class="font-semibold text-base">${server.name}</h4>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="status-dot status-${server.status}"></span>
                                <span class="capitalize text-xs text-gray-600">${server.status}</span>
                            </div>
                        </div>
                        <span class="text-xs px-2 py-1 rounded ${server.bottleneck === 'None' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">${server.bottleneck}</span>
                    </div>
                    <div class="space-y-2">
                        <div>
                            <div class="flex items-center justify-between text-xs mb-1">
                                <span class="text-gray-600">CPU</span>
                                <span class="font-medium">${server.cpu}%</span>
                            </div>
                            <div class="metric-bar">
                                <div class="metric-fill" style="width: ${server.cpu}%; background: ${server.cpu > 85 ? '#D32F2F' : server.cpu > 70 ? '#F57C00' : '#388E3C'}"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center justify-between text-xs mb-1">
                                <span class="text-gray-600">Memory</span>
                                <span class="font-medium">${server.memory}%</span>
                            </div>
                            <div class="metric-bar">
                                <div class="metric-fill" style="width: ${server.memory}%; background: ${server.memory > 90 ? '#D32F2F' : server.memory > 75 ? '#F57C00' : '#388E3C'}"></div>
                            </div>
                        </div>
                        <div class="flex items-center justify-between text-xs">
                            <span class="text-gray-600">Disk I/O</span>
                            <span class="font-medium">${server.diskio}ms</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // Tab navigation handler
        function switchTab(tab) {
            const allLinks = document.querySelectorAll('.sidebar-link, .mobile-tab-item');
            allLinks.forEach(l => l.classList.remove('active'));
            
            document.querySelectorAll(`[data-tab="${tab}"]`).forEach(l => l.classList.add('active'));
            
            document.querySelectorAll('.tab-content').forEach(content => content.classList.add('hidden'));
            document.getElementById(tab).classList.remove('hidden');
            
            if (window.innerWidth < 768) {
                document.getElementById('sidebar').classList.add('-translate-x-full');
                document.getElementById('overlay').classList.add('hidden');
            }
            
            if (tab === 'analysis') {
                setTimeout(renderCharts, 100);
            }
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Tab navigation for sidebar and mobile tab bar
        document.querySelectorAll('.sidebar-link, .mobile-tab-item').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const tab = link.dataset.tab;
                switchTab(tab);
            });
        });

        // Mobile menu toggle
        document.getElementById('menuToggle').addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        });

        document.getElementById('overlay').addEventListener('click', () => {
            document.getElementById('sidebar').classList.add('-translate-x-full');
            document.getElementById('overlay').classList.add('hidden');
        });

        // Form submissions
        document.getElementById('monitoringForm').addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Monitoring preferences saved successfully!\n\nConfiguration will be applied via COM/DCOM interface to the backend service.');
        });

        document.getElementById('applyLicense').addEventListener('click', () => {
            const key = document.getElementById('licenseKey').value;
            if (!key || !key.startsWith('HPPA-')) {
                alert('Please enter a valid license key in format: HPPA-YYYY-XXXX-XXXX');
                return;
            }
            alert('License applied successfully!\n\nServer is now being monitored by Compaq Inside Manager.\nLicense validation completed via Licensing COM Component.');
            document.getElementById('licenseKey').value = '';
        });

        // Chart configuration
        const chartOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: { beginAtZero: true, max: 100 },
                x: { 
                    ticks: {
                        maxRotation: 0,
                        autoSkip: true,
                        maxTicksLimit: 8
                    }
                }
            }
        };

        let cpuChart, memoryChart, diskChart;

        function renderCharts() {
            const labels = Array.from({length: 24}, (_, i) => `${i}:00`);
            
            // CPU Chart
            const cpuCtx = document.getElementById('cpuChart');
            if (cpuCtx) {
                if (cpuChart) cpuChart.destroy();
                cpuChart = new Chart(cpuCtx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: labels.map(() => Math.random() * 40 + 50),
                            borderColor: '#0096D6',
                            backgroundColor: 'rgba(0, 150, 214, 0.1)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: chartOptions
                });
            }

            // Memory Chart
            const memoryCtx = document.getElementById('memoryChart');
            if (memoryCtx) {
                if (memoryChart) memoryChart.destroy();
                memoryChart = new Chart(memoryCtx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: labels.map(() => Math.random() * 30 + 60),
                            borderColor: '#F57C00',
                            backgroundColor: 'rgba(245, 124, 0, 0.1)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: chartOptions
                });
            }

            // Disk Chart
            const diskCtx = document.getElementById('diskChart');
            if (diskCtx) {
                if (diskChart) diskChart.destroy();
                const diskData = labels.map(() => Math.random() * 80 + 80);
                diskChart = new Chart(diskCtx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: diskData,
                            borderColor: '#D32F2F',
                            backgroundColor: 'rgba(211, 47, 47, 0.1)',
                            tension: 0.4,
                            fill: true,
                            segment: {
                                borderColor: ctx => ctx.p0.parsed.y > 100 ? '#D32F2F' : '#0096D6'
                            }
                        }]
                    },
                    options: {
                        ...chartOptions,
                        scales: {
                            y: { beginAtZero: true, max: 200 },
                            x: chartOptions.scales.x
                        }
                    }
                });
            }
        }

        // Initialize
        renderServerTable();
        renderServerCards();

        // Handle window resize for charts
        let resizeTimer;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(() => {
                if (document.getElementById('analysis').classList.contains('hidden') === false) {
                    renderCharts();
                }
            }, 250);
        });
    </script>
